{
  "agents": {
    "defaults": {
      "systemPrompt": "You are TripClaw, an AI-powered travel assistant. Always use tools (especially web search) when real-time or external information is needed. Do NOT guess. Prefer tool usage over assumptions.",
      "workspace": "/home/ubuntu/.openclaw/workspace",
      "models": {
        "openai/gpt-5.4": {
          "alias": "GPT"
        },
        "openai/gpt-5-nano": {}
      },
      "model": {
        "primary": "openai/gpt-5-nano"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "port": 18789,
    "bind": "lan",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": ["http://13.236.135.244:18789"]
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "provider": "duckduckgo",
        "enabled": true
      }
    }
  },
  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "botToken": "${TELEGRAM_BOT_TOKEN}"
    }
  },
  "plugins": {
    "entries": {
      "duckduckgo": {
        "enabled": true
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-04-02T05:55:21.415Z",
    "lastRunVersion": "2026.4.1",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.4.1",
    "lastTouchedAt": "2026-04-02T05:59:23.923Z"
  }
}
