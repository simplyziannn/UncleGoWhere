{
  "name": "itinerary-planner-lite",
  "description": "Weather-aware itinerary builder using attractions, restaurants, events, and route grouping.",
  "inputs": {
    "destination": {"type": "string", "description": "Destination city or region"},
    "start_date": {"type": "string", "format": "YYYY-MM-DD", "optional": true},
    "end_date": {"type": "string", "format": "YYYY-MM-DD", "optional": true},
    "days": {"type": "integer", "optional": true},
    "traveler_type": {"type": "string", "optional": true},
    "budget_style": {"type": "string", "enum": ["budget", "balanced", "premium"], "default": "balanced"},
    "interests": {"type": "array", "items": {"type": "string"}, "optional": true},
    "pace": {"type": "string", "enum": ["slow", "balanced", "fast"], "default": "balanced"},
    "must_see": {"type": "array", "items": {"type": "string"}, "optional": true},
    "dietary_constraints": {"type": "array", "items": {"type": "string"}, "optional": true},
    "review_place": {"type": "string", "description": "Optional restaurant name for top recent review lookup", "optional": true},
    "translate_reviews_to_english": {"type": "boolean", "description": "Translate returned reviews into English using the OpenAI API when OPENAI_API_KEY is configured", "optional": true}
  },
  "outputs": {
    "header": "Itinerary for {DESTINATION} ({DATES})",
    "days": [
      {
        "title": "string",
        "morning": "string",
        "afternoon": "string",
        "evening": "string",
        "notes": "string",
        "morning_place": {"name": "string", "address": "string", "url": "string"},
        "afternoon_place": {"name": "string", "address": "string", "url": "string"},
        "lunch_place": {"name": "string", "address": "string", "url": "string"},
        "dinner_place": {"name": "string", "address": "string", "url": "string"}
      }
    ],
    "review_place": {
      "restaurant": {"name": "string", "address": "string", "url": "string", "rating": "number", "review_count": "integer"},
      "reviews": [
        {"author": "string", "rating": "number", "published": "string", "content": "string", "translated_content_en": "string", "snippet": "string"}
      ],
      "used_fallback_summary": "boolean",
      "fallback_summary": {"average_rating": "number", "total_reviews": "integer"}
    }
  }
}
